# 复制为 .env 并按需填值；.env 在 .gitignore 中不会被提交
# -----------------------------------------------------------------------------

# 主机标识：写入 SSH config 的 Host <user>-<HOSTNAME>
# 默认取 `hostname` 命令；显式覆盖时填这里
HOSTNAME=your-hostname

# 默认登录 IP（设置后跳过自动检测；为空则探测本机首个非 127 IPv4）
HOST_IP=

# 默认 home 父目录（默认 /home；如想用 /data/home 等替代）
UM_HOME_PARENT=/home

# 默认是否部署 ~/scripts（templates/）（默认 false）
UM_DEPLOY_SCRIPTS_DEFAULT=false

# 默认是否在 .bashrc 写 proxy 段（默认 false）
UM_CONFIGURE_PROXY_DEFAULT=false
